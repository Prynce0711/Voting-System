generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  fullname  String
  address   String
  gender    String
  createdAt DateTime @default(now())
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Candidate {
  id        Int      @id @default(autoincrement())
  name      String
  position  String
  createdAt DateTime @default(now())
  votes     Vote[]

  @@index([position])
}

model Vote {
  id          Int       @id @default(autoincrement())
  candidateId Int
  position    String
  createdAt   DateTime  @default(now())
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([position])
}
